{
  "python.defaultInterpreterPath": "${workspaceFolder}\\venv\\Scripts\\python.exe",

  "files.exclude": {
    "**/.git": true,
    "**/.pytest_cache": true,
    "**/__pycache__": true,
    "**/venv": true
  },

  "search.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/venv": true
  },

  "files.watcherExclude": {
    "**/.git/**": true,
    "**/__pycache__/**": true,
    "**/venv/**": true
  },

  "python.analysis.exclude": [
    "**/venv",
    "**/__pycache__"
  ],

  "terminal.integrated.scrollback": 2000,
  "python.terminal.activateEnvironment": true
}